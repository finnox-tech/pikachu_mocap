<!-- actuators.xml -->
<mujoco>
    <actuator>

        <motor class="DM-J4310P-2EC-V1.1"  name="act_Lhip_pitch" joint="left_hip_pitch_joint"/>
        <motor class="DM-J3507-2EC-3R" name="act_Lhip_roll" joint="left_hip_roll_joint"/>
        <motor class="DM-J3507-2EC-3R" name="act_Lhip_yaw" joint="left_hip_yaw_joint"/>
        <motor class="DM-J4310P-2EC-V1.1"   name="act_Lknee" joint="left_knee_joint"/>
        <motor class="DM-J3507-2EC-3R" name="act_Lankle" joint="left_ankle_joint"/>
        
        <motor class="DM-J4310P-2EC-V1.1"   name="act_Rhip_pitch" joint="right_hip_pitch_joint"/>
        <motor class="DM-J3507-2EC-3R" name="act_Rhip_roll" joint="right_hip_roll_joint"/>
        <motor class="DM-J3507-2EC-3R" name="act_Rhip_yaw" joint="right_hip_yaw_joint"/>
        <motor class="DM-J4310P-2EC-V1.1"   name="act_Rknee" joint="right_knee_joint"/>
        <motor class="DM-J3507-2EC-3R" name="act_Rankle" joint="right_ankle_joint"/>

        <!-- arm -->
        <motor class="DM-J3507-2EC-3R" name="act_Larm_pitch" joint="left_arm_pitch_joint"/>
        <motor class="DM-J3507-2EC-3R" name="act_Larm_roll" joint="left_arm_roll_joint"/>
        <motor class="DM-J3507-2EC" name="act_Larm_yaw" joint="left_arm_yaw_joint"/>
        <motor class="DM-J3507-2EC" name="act_Lelbow" joint="left_elbow_joint"/>

        <motor class="DM-J3507-2EC-3R" name="act_Rarm_pitch" joint="right_arm_pitch_joint"/>
        <motor class="DM-J3507-2EC-3R" name="act_Rarm_roll" joint="right_arm_roll_joint"/>
        <motor class="DM-J3507-2EC" name="act_Rarm_yaw" joint="right_arm_yaw_joint"/>
        <motor class="DM-J3507-2EC" name="act_Relbow" joint="right_elbow_joint"/>

    </actuator>
</mujoco>
